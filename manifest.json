{
  "manifest_version": 3,
  "name": "Better Browser MCP",
  "version": "0.3.0",
  "description": "Multi-agent browser automation with multi-tab support. Forks @browsermcp with configurable WebSocket endpoints, per-tab agent binding, and per-tab labels for multi-site workflows (e.g. Stripe + OpenAI console from one agent).",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Better Browser MCP"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
