{
  "manifest_version": 3,
  "name": "Better Browser MCP",
  "version": "0.2.0",
  "description": "Multi-agent browser automation. Forks @browsermcp with configurable WebSocket endpoints and per-tab agent binding.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Better Browser MCP"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
